{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-v4-pro",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 0.0,
    "analysis_concurrency": 3,
    "enrichment_concurrency": 3,
    "languages": [
      "zh"
    ]
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "owner": "openssl",
        "repo": "openssl",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "cloudflare",
        "repo": "circl",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "libressl",
        "repo": "portable",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 50
    },
    "rss": [
      {
        "name": "IACR ePrint 密码学论文",
        "url": "https://eprint.iacr.org/rss/rss.xml?format=nonstandard",
        "enabled": true,
        "category": "pqc"
      },
      {
        "name": "Cloudflare Blog (PQ 迁移)",
        "url": "https://blog.cloudflare.com/rss/",
        "enabled": true,
        "category": "pqc"
      },
      {
        "name": "Neil Madden (后量子密码)",
        "url": "https://neilmadden.blog/feed/",
        "enabled": true,
        "category": "pqc"
      },
      {
        "name": "Filippo Valsorda (Go 密码学)",
        "url": "https://words.filippo.io/feed/",
        "enabled": true,
        "category": "pqc"
      },
      {
        "name": "Schneier on Security",
        "url": "https://www.schneier.com/feed/",
        "enabled": true,
        "category": "pqc"
      },
      {
        "name": "Trail of Bits Blog",
        "url": "https://blog.trailofbits.com/feed/",
        "enabled": true,
        "category": "pqc"
      },
      {
        "name": "IETF Blog (标准动态)",
        "url": "https://www.ietf.org/blog/feed/",
        "enabled": true,
        "category": "pqc"
      },
      {
        "name": "IETF 新标准 RFC (PQC 标准化)",
        "url": "https://datatracker.ietf.org/feed/rfc/",
        "enabled": true,
        "category": "pqc"
      },
      {
        "name": "NIST Cybersecurity (安全公告)",
        "url": "https://www.nist.gov/news-events/cybersecurity/rss.xml",
        "enabled": true,
        "category": "pqc"
      },
      {
        "name": "NIST CSRC Drafts (标准草案)",
        "url": "https://csrc.nist.gov/CSRC/media/feeds/pubs/drafts-open-for-comment.xml",
        "enabled": true,
        "category": "pqc"
      },
      {
        "name": "GSMA Newsroom (移动安全标准)",
        "url": "https://www.gsma.com/newsroom/feed/",
        "enabled": true,
        "category": "pqc"
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [],
      "users": [],
      "fetch_comments": 5
    },
    "telegram": {
      "enabled": false,
      "channels": []
    },
    "sca": {
      "enabled": true,
      "announcements_url": null,
      "max_items": 10
    },
    "twitter": null,
    "openbb": null,
    "ossinsight": {
      "enabled": false,
      "period": "past_24_hours",
      "languages": [
        "All"
      ],
      "keywords": [],
      "min_stars": 10,
      "max_items": 20
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 72,
    "max_items": 20,
    "category_groups": {
      "pqc": {
        "name": "抗量子密码",
        "limit": 15,
        "categories": [
          "pqc"
        ]
      }
    },
    "default_group": "other",
    "default_group_limit": 0
  },
  "email": {
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "imap_enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "smtp_username": null,
    "email_address": "2450803404@qq.com",
    "password_env": "EMAIL_PASSWORD",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE",
    "enabled": true
  },
  "webhook": null
}
